# ── API ──────────────────────────────────────────────────
VITE_API_URL=https://qwillio.onrender.com

# ── Google OAuth ─────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Sentry (frontend error reporting) ────────────────────
# Leave empty in development to silence Sentry. Set in Vercel env vars
# for preview + production deployments. Get the DSN from your Sentry
# project settings → Client Keys (DSN).
VITE_SENTRY_DSN=
VITE_APP_VERSION=2.0.0
