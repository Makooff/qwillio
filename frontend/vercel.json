{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://qwillio.com/$1",
      "has": [{ "type": "host", "value": "www.qwillio.com" }],
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/privacy",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/gdpr",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/terms",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://qwillio.onrender.com/api/$1" },
    { "source": "/demo.html", "destination": "/demo.html" },
    { "source": "/demo-marie.html", "destination": "/demo-marie.html" },
    { "source": "/onboarding.html", "destination": "/onboarding.html" },
    { "source": "/client-portal.html", "destination": "/client-portal.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
