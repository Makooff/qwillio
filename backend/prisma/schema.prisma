  createdAt   DateTime @default(now()) @map("created_at")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, phoneNumber])
  @@index([clientId])
  @@map("spam_numbers")
}

