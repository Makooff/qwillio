generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique @db.VarChar(255)
  passwordHash        String?              @map("password_hash") @db.VarChar(255)
  name                String               @db.VarChar(255)
  role                String               @default("user") @db.VarChar(50)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  businessName        String?              @map("business_name") @db.VarChar(500)
  businessPhone       String?              @map("business_phone") @db.VarChar(50)
  confirmationToken   String?              @unique @map("confirmation_token") @db.VarChar(255)
  resetToken          String?              @unique @map("reset_token") @db.VarChar(255)
  resetTokenExpiry    DateTime?            @map("reset_token_expiry")
  emailConfirmed      Boolean              @default(false) @map("email_confirmed")
  onboardingCompleted Boolean              @default(false) @map("onboarding_completed")
  planType            String?              @map("plan_type") @db.VarChar(50)
  industry            String?              @db.VarChar(100)
  website             String?              @db.VarChar(500)
  googleId            String?              @unique @map("google_id") @db.VarChar(255)
  campaigns           Campaign[]
  client              Client?
  contractAcceptances ContractAcceptance[]
  prospects           Prospect[]
  trialFingerprints   TrialFingerprint[]
  agency              Agency?
  apiKeys             ApiKey[]

  @@map("users")
}

model LinkedInOutreach {
  id                  String    @id @default(cuid())
  prospectId          String?   @db.Uuid
  prospect            Prospect? @relation(fields: [prospectId], references: [id])
  linkedinUrl         String    @unique
  profileName         String?
  profileTitle        String?
  companyName         String?
  niche               String?
  connectionStatus    String    @default("pending")
  // pending → requested → connected → message1_sent → message2_sent → replied → qualified → not_interested
  connectionRequestAt DateTime?
  connectedAt         DateTime?
  message1SentAt      DateTime?
  message2SentAt      DateTime?
  lastReplyAt         DateTime?
  replyContent        String?
  interestScore       Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([connectionStatus])
  @@index([niche])
  @@map("linkedin_outreach")
}

model Prospect {
  id                    String                @id @default(uuid()) @db.Uuid
  businessName          String                @map("business_name") @db.VarChar(500)
  businessType          String                @map("business_type") @db.VarChar(100)
  sector                String?               @db.VarChar(100)
  address               String?               @db.VarChar(500)
  city                  String?               @db.VarChar(100)
  postalCode            String?               @map("postal_code") @db.VarChar(20)
  country               String                @default("US") @db.VarChar(10)
  phone                 String?               @db.VarChar(50)
  email                 String?               @db.VarChar(255)
  website               String?               @db.VarChar(500)
  contactName           String?               @map("contact_name") @db.VarChar(255)
  googlePlaceId         String?               @unique @map("google_place_id") @db.VarChar(255)
  googleRating          Float?                @map("google_rating")
  googleReviewsCount    Int?                  @map("google_reviews_count")
  googleTypes           String[]              @default([]) @map("google_types")
  score                 Int                   @default(0)
  status                String                @default("new") @db.VarChar(50)
  lastCallDate          DateTime?             @map("last_call_date")
  callDuration          Int?                  @map("call_duration")
  callTranscript        String?               @map("call_transcript")
  callSentiment         String?               @map("call_sentiment") @db.VarChar(50)
  interestLevel         Int?                  @map("interest_level")
  painPoints            String[]              @default([]) @map("pain_points")
  needsIdentified       String?               @map("needs_identified")
  notes                 String?
  nextAction            String?               @map("next_action") @db.VarChar(255)
  nextActionDate        DateTime?             @map("next_action_date")
  lastContactDate       DateTime?             @map("last_contact_date")
  assignedToUserId      String?               @map("assigned_to_user_id") @db.Uuid
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @default(now()) @updatedAt @map("updated_at")
  callAttempts          Int                   @default(0) @map("call_attempts")
  maxAttempts           Int                   @default(3) @map("max_attempts")
  phoneNumberConfidence Float?                @map("phone_number_confidence")
  phoneValidated        Boolean               @default(false) @map("phone_validated")
  phoneValidatedAt      DateTime?             @map("phone_validated_at")
  phoneValidationSource String?               @map("phone_validation_source") @db.VarChar(50)
  timezone              String                @default("America/New_York") @db.VarChar(50)
  emailBounced          Boolean               @default(false) @map("email_bounced")
  emailBouncedAt        DateTime?             @map("email_bounced_at")
  emailConfirmationId   String?               @map("email_confirmation_id") @db.VarChar(255)
  emailSmsFollowupSent  Boolean               @default(false) @map("email_sms_followup_sent")
  emailSmsReplyRaw      String?               @map("email_sms_reply_raw")
  emailVerified         Boolean               @default(false) @map("email_verified")
  emailVerifiedAt       DateTime?             @map("email_verified_at")
  emailUnsubscribed     Boolean               @default(false) @map("email_unsubscribed")
  emailUnsubscribedAt   DateTime?             @map("email_unsubscribed_at")
  smsOptedOut           Boolean               @default(false) @map("sms_opted_out")
  smsOptedOutAt         DateTime?             @map("sms_opted_out_at")
  carrier               String?               @db.VarChar(100)
  eligibleForCall       Boolean               @default(true) @map("eligible_for_call")
  isMobile              Boolean               @default(false) @map("is_mobile")
  lineType              String?               @map("line_type") @db.VarChar(50)
  nextCallAt            DateTime?             @map("next_call_at")
  niche                 String?               @db.VarChar(100)
  enrichedData          Json?                 @map("enriched_data")
  priorityScore         Int                   @default(0) @map("priority_score")
  scriptVariantUsed     String?               @map("script_variant_used") @db.VarChar(10)
  state                 String?               @db.VarChar(50)
  isFavorite            Boolean               @default(false) @map("is_favorite")
  calls                 Call[]
  campaignSends         CampaignSend[]
  clients               Client[]
  followUpSequences     FollowUpSequence[]
  bookingSlots          ProspectBookingSlot[]
  assignedTo            User?                 @relation(fields: [assignedToUserId], references: [id])
  quotes                Quote[]
  smsLogs               SmsLog[]
  linkedInOutreach      LinkedInOutreach[]

  @@index([status])
  @@index([businessType])
  @@index([city])
  @@index([score])
  @@index([priorityScore])
  @@index([niche])
  @@index([eligibleForCall])
  @@map("prospects")
}

model Call {
  id                      String    @id @default(uuid()) @db.Uuid
  prospectId              String?   @map("prospect_id") @db.Uuid
  vapiCallId              String?   @unique @map("vapi_call_id") @db.VarChar(255)
  phoneNumber             String    @map("phone_number") @db.VarChar(50)
  direction               String    @default("outbound") @db.VarChar(20)
  startedAt               DateTime? @map("started_at")
  endedAt                 DateTime? @map("ended_at")
  durationSeconds         Int?      @map("duration_seconds")
  status                  String    @default("queued") @db.VarChar(50)
  transcript              String?
  summary                 String?
  sentiment               String?   @db.VarChar(50)
  interestLevel           Int?      @map("interest_level")
  emailCollected          String?   @map("email_collected") @db.VarChar(255)
  needsMentioned          String[]  @default([]) @map("needs_mentioned")
  objections              String[]  @default([])
  budgetMentioned         String?   @map("budget_mentioned") @db.VarChar(100)
  timelineMentioned       String?   @map("timeline_mentioned") @db.VarChar(100)
  decisionMakerReached    Boolean   @default(false) @map("decision_maker_reached")
  outcome                 String?   @db.VarChar(100)
  recommendedPackage      String?   @map("recommended_package") @db.VarChar(50)
  nextAction              String?   @map("next_action") @db.VarChar(255)
  recordingUrl            String?   @map("recording_url") @db.VarChar(500)
  cost                    Decimal?  @db.Decimal(10, 4)
  createdAt               DateTime  @default(now()) @map("created_at")
  metadata                Json?
  setupFeeObjectionRaised Boolean   @default(false) @map("setup_fee_objection_raised")
  qualityScore            Int?      @map("quality_score")
  scriptDropOffPoint      String?   @map("script_drop_off_point") @db.VarChar(50)
  claudeSummary           String?   @map("claude_summary")
  detectionResult         String?   @map("detection_result") @db.VarChar(50)
  interestScore           Int?      @map("interest_score")
  language                String?   @db.VarChar(10)
  leadCaptured            Boolean   @default(false) @map("lead_captured")
  niche                   String?   @db.VarChar(100)
  scriptVariant           String?   @map("script_variant") @db.VarChar(10)
  transferRequested       Boolean   @default(false) @map("transfer_requested")
  twilioNumberUsed        String?   @map("twilio_number_used") @db.VarChar(50)
  agentConfidenceScore    Int?      @map("agent_confidence_score")
  callQualityScore        Int?      @map("call_quality_score")
  dropOffReason           String?   @map("drop_off_reason")
  fillerWordsUsed         String[]  @default([]) @map("filler_words_used")
  keyObjection            String?   @map("key_objection")
  missedOpportunity       String?   @map("missed_opportunity")
  prospectPainLevel       Int?      @map("prospect_pain_level")
  prospectSentiment       String?   @map("prospect_sentiment") @db.VarChar(50)
  recommendedMicroFix     String?   @map("recommended_micro_fix")
  sentimentShift          String?   @map("sentiment_shift") @db.VarChar(20)
  sentimentTimeline       Json?     @map("sentiment_timeline")
  whatFailed              String?   @map("what_failed")
  whatWorked              String?   @map("what_worked")
  prospect                Prospect? @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([status])
  @@index([niche])
  @@index([detectionResult])
  @@map("calls")
}

model Quote {
  id                  String    @id @default(uuid()) @db.Uuid
  prospectId          String?   @map("prospect_id") @db.Uuid
  packageType         String    @map("package_type") @db.VarChar(50)
  setupFee            Decimal   @map("setup_fee") @db.Decimal(10, 2)
  monthlyFee          Decimal   @map("monthly_fee") @db.Decimal(10, 2)
  currency            String    @default("USD") @db.VarChar(10)
  featuresIncluded    Json      @map("features_included")
  validUntil          DateTime  @map("valid_until") @db.Date
  status              String    @default("sent") @db.VarChar(50)
  sentAt              DateTime? @map("sent_at")
  viewedAt            DateTime? @map("viewed_at")
  acceptedAt          DateTime? @map("accepted_at")
  stripePaymentLink   String?   @map("stripe_payment_link") @db.VarChar(500)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  notes               String?
  installmentMonths   Int       @default(1) @map("installment_months")
  setupFeeInstallment Boolean   @default(false) @map("setup_fee_installment")
  contractPdfUrl      String?   @map("contract_pdf_url") @db.VarChar(500)
  contractSignedAt    DateTime? @map("contract_signed_at")
  docusignEnvelopeId  String?   @map("docusign_envelope_id") @db.VarChar(100)
  clients             Client[]
  prospect            Prospect? @relation(fields: [prospectId], references: [id])

  @@index([prospectId])
  @@index([status])
  @@map("quotes")
}

model Client {
  id                         String                    @id @default(uuid()) @db.Uuid
  prospectId                 String?                   @map("prospect_id") @db.Uuid
  quoteId                    String?                   @map("quote_id") @db.Uuid
  businessName               String                    @map("business_name") @db.VarChar(500)
  businessType               String                    @map("business_type") @db.VarChar(100)
  sector                     String?                   @db.VarChar(100)
  contactName                String                    @map("contact_name") @db.VarChar(255)
  contactEmail               String                    @map("contact_email") @db.VarChar(255)
  contactPhone               String?                   @map("contact_phone") @db.VarChar(50)
  address                    String?                   @db.VarChar(500)
  city                       String?                   @db.VarChar(100)
  postalCode                 String?                   @map("postal_code") @db.VarChar(20)
  country                    String                    @default("BE") @db.VarChar(10)
  planType                   String                    @map("plan_type") @db.VarChar(50)
  setupFee                   Decimal                   @map("setup_fee") @db.Decimal(10, 2)
  monthlyFee                 Decimal                   @map("monthly_fee") @db.Decimal(10, 2)
  currency                   String                    @default("EUR") @db.VarChar(10)
  stripeCustomerId           String?                   @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId       String?                   @unique @map("stripe_subscription_id") @db.VarChar(255)
  subscriptionStatus         String                    @default("active") @map("subscription_status") @db.VarChar(50)
  vapiAssistantId            String?                   @map("vapi_assistant_id") @db.VarChar(255)
  vapiPhoneNumber            String?                   @map("vapi_phone_number") @db.VarChar(50)
  vapiConfig                 Json?                     @map("vapi_config")
  onboardingStatus           String                    @default("pending") @map("onboarding_status") @db.VarChar(50)
  onboardingCompletedAt      DateTime?                 @map("onboarding_completed_at")
  activationDate             DateTime?                 @map("activation_date")
  cancellationDate           DateTime?                 @map("cancellation_date")
  totalCallsMade             Int                       @default(0) @map("total_calls_made")
  monthlyCallsQuota          Int?                      @map("monthly_calls_quota")
  monthlyMinutesQuota        Int?                      @map("monthly_minutes_quota")
  lastCallDate               DateTime?                 @map("last_call_date")
  notes                      String?
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @default(now()) @updatedAt @map("updated_at")
  isTrial                    Boolean                   @default(false) @map("is_trial")
  trialConvertedAt           DateTime?                 @map("trial_converted_at")
  trialEndDate               DateTime?                 @map("trial_end_date")
  trialStartDate             DateTime?                 @map("trial_start_date")
  addOns                     Json?                     @map("add_ons")
  contractSignedAt           DateTime?                 @map("contract_signed_at")
  contractUrl                String?                   @map("contract_url") @db.VarChar(500)
  dashboardToken             String?                   @unique @map("dashboard_token") @db.VarChar(255)
  loomVideoUrl               String?                   @map("loom_video_url") @db.VarChar(500)
  onboardingData             Json?                     @map("onboarding_data")
  onboardingFormDoneAt       DateTime?                 @map("onboarding_form_done_at")
  onboardingFormSentAt       DateTime?                 @map("onboarding_form_sent_at")
  transferNumber             String?                   @map("transfer_number") @db.VarChar(50)
  userId                     String?                   @unique @map("user_id") @db.Uuid
  googleCalendarId           String?                   @map("google_calendar_id") @db.VarChar(255)
  googleCalendarRefreshToken String?                   @map("google_calendar_refresh_token")
  agentLanguage              String                    @default("en") @map("agent_language") @db.VarChar(10)
  agentName                  String?                   @map("agent_name") @db.VarChar(100)
  forwardingStatus           String?                   @map("forwarding_status") @db.VarChar(50)
  forwardingType             String?                   @map("forwarding_type") @db.VarChar(50)
  forwardingVerifiedAt       DateTime?                 @map("forwarding_verified_at")
  activities                 Activity[]
  agentAccounting            AgentAccounting?
  agentEmailConfigs          AgentEmailConfig?
  agentEmails                AgentEmail[]
  agentExpenses              AgentExpense[]
  agentFinancialReports      AgentFinancialReport[]
  agentIncomes               AgentIncome[]
  agentInventory             AgentInventory[]
  agentInventoryLogs         AgentInventoryLog[]
  agentInvoices              AgentInvoice[]
  agentReorderRequests       AgentReorderRequest[]
  agentSubscriptions         AgentSubscription?
  agentMarketingConfig       AgentMarketingConfig?
  agentMarketingActivities   AgentMarketingActivity[]
  agentReputationConfig      AgentReputationConfig?
  agentReputationActivities  AgentReputationActivity[]
  agentSchedulingConfig      AgentSchedulingConfig?
  agentSchedulingActivities  AgentSchedulingActivity[]
  agentSupportConfig         AgentSupportConfig?
  agentSupportActivities     AgentSupportActivity[]
  agentCrmConfig             AgentCrmConfig?
  agentCrmActivities         AgentCrmActivity[]
  agentDocumentConfig        AgentDocumentConfig?
  agentDocumentActivities    AgentDocumentActivity[]
  agentLocalSeoConfig        AgentLocalSeoConfig?
  agentLocalSeoActivities    AgentLocalSeoActivity[]
  agentLeadGenConfig         AgentLeadGenConfig?
  agentLeadGenActivities     AgentLeadGenActivity[]
  agentAnalyticsConfig       AgentAnalyticsConfig?
  agentAnalyticsActivities   AgentAnalyticsActivity[]
  callTransfers              CallTransfer[]
  clientAnalytics            ClientAnalyticsDaily[]
  clientBookings             ClientBooking[]
  clientCalls                ClientCall[]
  spamNumbers                SpamNumber[]
  prospect                   Prospect?                 @relation(fields: [prospectId], references: [id])
  quote                      Quote?                    @relation(fields: [quoteId], references: [id])
  user                       User?                     @relation(fields: [userId], references: [id])
  contacts                   Contact[]
  contractAcceptances        ContractAcceptance[]
  crmIntegrations            CrmIntegration[]
  deals                      Deal[]
  payments                   Payment[]
  smsLogs                    SmsLog[]
  syncConflicts              SyncConflict[]
  syncLogs                   SyncLog[]

  agencyClients AgencyClient[]

  @@index([subscriptionStatus])
  @@index([planType])
  @@index([onboardingStatus])
  @@map("clients")
}

model Campaign {
  id                  String         @id @default(uuid()) @db.Uuid
  name                String         @db.VarChar(255)
  type                String         @default("email") @db.VarChar(50)
  targetBusinessTypes String[]       @default([]) @map("target_business_types")
  targetCities        String[]       @default([]) @map("target_cities")
  targetMinScore      Int?           @map("target_min_score")
  targetMaxScore      Int?           @map("target_max_score")
  targetStatuses      String[]       @default([]) @map("target_statuses")
  subjectLine         String?        @map("subject_line") @db.VarChar(255)
  messageTemplate     String         @map("message_template")
  scheduledDate       DateTime?      @map("scheduled_date")
  status              String         @default("draft") @db.VarChar(50)
  sentCount           Int            @default(0) @map("sent_count")
  deliveredCount      Int            @default(0) @map("delivered_count")
  openedCount         Int            @default(0) @map("opened_count")
  clickedCount        Int            @default(0) @map("clicked_count")
  repliedCount        Int            @default(0) @map("replied_count")
  bouncedCount        Int            @default(0) @map("bounced_count")
  createdByUserId     String?        @map("created_by_user_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at")
  completedAt         DateTime?      @map("completed_at")
  sends               CampaignSend[]
  createdBy           User?          @relation(fields: [createdByUserId], references: [id])

  @@index([status])
  @@map("campaigns")
}

model CampaignSend {
  id           String    @id @default(uuid()) @db.Uuid
  campaignId   String    @map("campaign_id") @db.Uuid
  prospectId   String    @map("prospect_id") @db.Uuid
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  openedAt     DateTime? @map("opened_at")
  clickedAt    DateTime? @map("clicked_at")
  repliedAt    DateTime? @map("replied_at")
  bouncedAt    DateTime? @map("bounced_at")
  status       String    @default("pending") @db.VarChar(50)
  errorMessage String?   @map("error_message")
  messageId    String?   @map("message_id") @db.VarChar(255)
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prospectId])
  @@index([campaignId])
  @@index([prospectId])
  @@map("campaign_sends")
}

model Reminder {
  id           String    @id @default(uuid()) @db.Uuid
  targetType   String    @map("target_type") @db.VarChar(50)
  targetId     String    @map("target_id") @db.Uuid
  reminderType String    @map("reminder_type") @db.VarChar(50)
  scheduledAt  DateTime  @map("scheduled_at")
  status       String    @default("pending") @db.VarChar(50)
  sentAt       DateTime? @map("sent_at")
  result       String?
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@map("reminders")
}

model Payment {
  id                    String    @id @default(uuid()) @db.Uuid
  clientId              String?   @map("client_id") @db.Uuid
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeInvoiceId       String?   @map("stripe_invoice_id") @db.VarChar(255)
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("EUR") @db.VarChar(10)
  paymentType           String    @map("payment_type") @db.VarChar(50)
  status                String    @default("pending") @db.VarChar(50)
  paidAt                DateTime? @map("paid_at")
  failedAt              DateTime? @map("failed_at")
  refundedAt            DateTime? @map("refunded_at")
  description           String?
  failureReason         String?   @map("failure_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  metadata              Json?
  client                Client?   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("payments")
}

model WebhookLog {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @db.VarChar(50)
  eventType    String    @map("event_type") @db.VarChar(100)
  payload      Json
  headers      Json?
  status       String    @default("received") @db.VarChar(50)
  processedAt  DateTime? @map("processed_at")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([source])
  @@index([status])
  @@map("webhook_logs")
}

model SmsLog {
  id          String    @id @default(uuid()) @db.Uuid
  to          String    @db.VarChar(50)
  body        String
  messageType String    @map("message_type") @db.VarChar(50)
  twilioSid   String?   @map("twilio_sid") @db.VarChar(100)
  status      String    @default("sent") @db.VarChar(20)
  errorMsg    String?   @map("error_msg")
  prospectId  String?   @map("prospect_id") @db.Uuid
  clientId    String?   @map("client_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  client      Client?   @relation(fields: [clientId], references: [id])
  prospect    Prospect? @relation(fields: [prospectId], references: [id])

  @@index([to])
  @@index([messageType])
  @@index([createdAt])
  @@map("sms_logs")
}

model AnalyticsDaily {
  id                   String   @id @default(uuid()) @db.Uuid
  date                 DateTime @unique @db.Date
  prospectsAdded       Int      @default(0) @map("prospects_added")
  prospectsContacted   Int      @default(0) @map("prospects_contacted")
  prospectsQualified   Int      @default(0) @map("prospects_qualified")
  callsMade            Int      @default(0) @map("calls_made")
  callsSuccessful      Int      @default(0) @map("calls_successful")
  callsFailed          Int      @default(0) @map("calls_failed")
  totalCallDuration    Int      @default(0) @map("total_call_duration")
  quotesSent           Int      @default(0) @map("quotes_sent")
  quotesAccepted       Int      @default(0) @map("quotes_accepted")
  newClients           Int      @default(0) @map("new_clients")
  revenueSetupFees     Decimal  @default(0) @map("revenue_setup_fees") @db.Decimal(10, 2)
  revenueSubscriptions Decimal  @default(0) @map("revenue_subscriptions") @db.Decimal(10, 2)
  costVapiCalls        Decimal  @default(0) @map("cost_vapi_calls") @db.Decimal(10, 4)
  costApis             Decimal  @default(0) @map("cost_apis") @db.Decimal(10, 4)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  costTwilioLookup     Decimal  @default(0) @map("cost_twilio_lookup") @db.Decimal(10, 4)
  costTwilioSms        Decimal  @default(0) @map("cost_twilio_sms") @db.Decimal(10, 4)
  phonesValidated      Int      @default(0) @map("phones_validated")
