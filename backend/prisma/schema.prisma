// ═══════════════════════════════════════════════════════════
// AGENT INVENTORY LOGS — Stock movement history
// ═══════════════════════════════════════════════════════════
model AgentInventoryLog {
  id              String   @id @default(uuid()) @db.Uuid
  inventoryId     String   @map("inventory_id") @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  changeType      String   @map("change_type") @db.VarChar(50)
  quantityChange  Decimal  @map("quantity_change") @db.Decimal(10, 2)
  quantityAfter   Decimal  @map("quantity_after") @db.Decimal(10, 2)
  note            String?  @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")

  inventory AgentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([clientId])
  @@index([createdAt])
  @@map("agent_inventory_logs")
}

// ═══════════════════════════════════════════════════════════
// AGENT REORDER REQUESTS — Auto-reorder history
// ═══════════════════════════════════════════════════════════
model AgentReorderRequest {
  id            String    @id @default(uuid()) @db.Uuid
  inventoryId   String    @map("inventory_id") @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  supplierEmail String    @map("supplier_email") @db.VarChar(255)
  quantity      Decimal   @db.Decimal(10, 2)
  emailBody     String    @map("email_body") @db.Text
  status        String    @default("sent") @db.VarChar(50)
  sentAt        DateTime  @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  inventory AgentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("agent_reorder_requests")
}

// ═══════════════════════════════════════════════════════════
// AGENT EMAILS — Email AI classified emails
// ═══════════════════════════════════════════════════════════
model AgentEmail {
  id              String    @id @default(uuid()) @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  gmailMessageId  String    @unique @map("gmail_message_id") @db.VarChar(255)
  threadId        String?   @map("thread_id") @db.VarChar(255)
  fromAddress     String    @map("from_address") @db.VarChar(500)
  toAddress       String    @map("to_address") @db.VarChar(500)
  subject         String    @db.VarChar(1000)
  bodyPreview     String    @map("body_preview") @db.Text
  receivedAt      DateTime  @map("received_at")
  classification  String?   @db.VarChar(50)
  classificationConfidence Float? @map("classification_confidence")
  autoReplied     Boolean   @default(false) @map("auto_replied")
  autoReplyText   String?   @map("auto_reply_text") @db.Text
  needsFollowUp   Boolean   @default(false) @map("needs_follow_up")
  followUpAt      DateTime? @map("follow_up_at")
  followUpSent    Boolean   @default(false) @map("follow_up_sent")
  isRead          Boolean   @default(false) @map("is_read")
  createdAt       DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([classification])
  @@index([receivedAt])
  @@map("agent_emails")
}

// ═══════════════════════════════════════════════════════════
// SCRIPT MUTATIONS — AI self-learning script changes
// ═══════════════════════════════════════════════════════════
model ScriptMutation {
  id               String    @id @default(uuid()) @db.Uuid
  niche            String    @db.VarChar(100)
  language         String    @db.VarChar(10)
  type             String    @db.VarChar(50)
  changeApplied    String    @map("change_applied") @db.Text
  reason           String    @db.Text
  date             DateTime  @default(now())
  callsBefore      Int       @map("calls_before")
  conversionBefore Float     @map("conversion_before")
  callsAfter       Int       @default(0) @map("calls_after")
  conversionAfter  Float?    @map("conversion_after")
  status           String    @default("testing") @db.VarChar(50)
  confidenceScore  Int?      @map("confidence_score")
  revertedAt       DateTime? @map("reverted_at")
  revertReason     String?   @map("revert_reason") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([niche])
  @@index([status])
  @@map("script_mutations")
}

// ═══════════════════════════════════════════════════════════
// AI DECISIONS — Log of all AI system decisions
// ═══════════════════════════════════════════════════════════
model AiDecision {
  id              String   @id @default(uuid()) @db.Uuid
  timestamp       DateTime @default(now())
  type            String   @db.VarChar(50)
  niche           String?  @db.VarChar(100)
  language        String?  @db.VarChar(10)
  confidenceScore Int?     @map("confidence_score")
  dataPointsUsed  Int?     @map("data_points_used")
  outcome         String   @db.VarChar(50)
  details         Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([niche])
  @@map("ai_decisions")
}

// ═══════════════════════════════════════════════════════════
// SCRIPT A/B TESTS — Variant testing for call scripts
// ═══════════════════════════════════════════════════════════
model ScriptAbTest {
  id           String    @id @default(uuid()) @db.Uuid
  niche        String    @db.VarChar(100)
  language     String    @db.VarChar(10)
  variantA     String    @map("variant_a") @db.Text
  variantB     String    @map("variant_b") @db.Text
  callsA       Int       @default(0) @map("calls_a")
  conversionsA Int       @default(0) @map("conversions_a")
  callsB       Int       @default(0) @map("calls_b")
  conversionsB Int       @default(0) @map("conversions_b")
  winner       String?   @db.VarChar(10)
  decidedAt    DateTime? @map("decided_at")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([niche])
  @@map("script_ab_tests")
}

// ═══════════════════════════════════════════════════════════
// NICHE BEST TIMES — Optimal calling windows per niche
// ═══════════════════════════════════════════════════════════
model NicheBestTime {
  id           String   @id @default(uuid()) @db.Uuid
  niche        String   @db.VarChar(100)
  dayOfWeek    Int      @map("day_of_week")
  hourUtc      Int      @map("hour_utc")
  conversionRate Float  @map("conversion_rate")
  sampleSize   Int      @map("sample_size")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([niche, dayOfWeek, hourUtc])
  @@map("niche_best_times")
}

// ═══════════════════════════════════════════════════════════
// LOCAL PRESENCE NUMBERS — Area-code matched Twilio numbers
// ═══════════════════════════════════════════════════════════
model LocalPresenceNumber {
  id          String   @id @default(uuid()) @db.Uuid
  areaCode    String   @map("area_code") @db.VarChar(10)
  phoneNumber String   @unique @map("phone_number") @db.VarChar(20)
  twilioSid   String?  @map("twilio_sid") @db.VarChar(100)
  city        String?  @db.VarChar(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([areaCode])
  @@map("local_presence_numbers")
}

// ═══════════════════════════════════════════════════════════
// FOLLOW-UP SEQUENCES — Multi-channel follow-up tracking
// ═══════════════════════════════════════════════════════════
model FollowUpSequence {
  id          String    @id @default(uuid()) @db.Uuid
  prospectId  String    @map("prospect_id") @db.Uuid
  type        String    @db.VarChar(50)
  step        Int
  scheduledAt DateTime  @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  opened      Boolean   @default(false)
  clicked     Boolean   @default(false)
  replied     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([scheduledAt])
  @@index([sentAt])
  @@map("follow_up_sequences")
}

// ═══════════════════════════════════════════════════════════
// ADMIN CONFIG - Centralised remote configuration for Mission Control
// ═══════════════════════════════════════════════════════════
model AdminConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  // Bot Configuration
  callsPerDay            Int      @default(50) @map("calls_per_day")
  callWindowStart        Int      @default(9) @map("call_window_start")
  callWindowEnd          Int      @default(19) @map("call_window_end")
  activeDays             String[] @default(["monday","tuesday","wednesday","thursday","friday"]) @map("active_days")
  callIntervalMinutes    Int      @default(20) @map("call_interval_minutes")
  prospectionQuotaPerDay Int      @default(100) @map("prospection_quota_per_day")
  minPriorityScore       Int      @default(0) @map("min_priority_score")
  targetCities           String[] @default([]) @map("target_cities")
  // VAPI Configuration
  vapiAssistantId        String?  @map("vapi_assistant_id") @db.VarChar(255)
  vapiVoiceId            String?  @map("vapi_voice_id") @db.VarChar(100)
  maxCallDurationMin     Int      @default(10) @map("max_call_duration_min")
  silenceTimeoutSeconds  Int      @default(30) @map("silence_timeout_seconds")
  // Prospecting Configuration
  apifyActorId           String?  @map("apify_actor_id") @db.VarChar(255)
  targetNiches           String[] @default([]) @map("target_niches")
  apifyTargetCities      String[] @default([]) @map("apify_target_cities")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("admin_config")
}
