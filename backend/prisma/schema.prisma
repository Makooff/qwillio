  apifyTargetCities      String[] @default([]) @map("apify_target_cities")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("admin_config")
}

// ─── Prospect Auto-Booking ────────────────────────────────────────────────────

model ProspectBookingSlot {
  id           String    @id @default(uuid()) @db.Uuid
  prospectId   String    @map("prospect_id") @db.Uuid
  token        String    @unique @db.VarChar(64)
  slots        Json
  selectedSlot DateTime? @map("selected_slot")
  status       String    @default("pending") @db.VarChar(20)
  confirmedAt  DateTime? @map("confirmed_at")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([status])
  @@index([prospectId])
  @@map("prospect_booking_slots")
}

// ─── Agent Anomaly Alerts ─────────────────────────────────────────────────────

model AgentAnomaly {
  id           String    @id @default(uuid()) @db.Uuid
  metricName   String    @map("metric_name") @db.VarChar(100)
  currentValue Float     @map("current_value")
  avgValue     Float     @map("avg_value")
  deviation    Float
  diagnosis    String?   @db.Text
  severity     String    @default("warn") @db.VarChar(20)
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([metricName])
  @@index([severity])
  @@index([createdAt])
  @@map("agent_anomalies")
}

// ─── Self-Learning Agent System ───────────────────────────────────────────────

model AgentStrategy {
  id         String   @id @default(uuid()) @db.Uuid
  agentType  String   @map("agent_type") @db.VarChar(50)
  niche      String   @db.VarChar(100)
  language   String   @default("en") @db.VarChar(10)
  isActive   Boolean  @default(true) @map("is_active")
  version    Int      @default(1)
  playbook   Json
  winRate    Float    @default(0) @map("win_rate")
  sampleSize Int      @default(0) @map("sample_size")
  evolvedAt  DateTime @default(now()) @map("evolved_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([agentType, niche, language, isActive])
  @@index([agentType])
  @@index([niche])
  @@index([isActive])
  @@map("agent_strategies")
}

model AgentAction {
  id         String   @id @default(uuid()) @db.Uuid
  agentType  String   @map("agent_type") @db.VarChar(50)
  prospectId String?  @map("prospect_id") @db.Uuid
  niche      String?  @db.VarChar(100)
  language   String   @default("en") @db.VarChar(10)
  strategyId String?  @map("strategy_id") @db.Uuid
  input      Json
  output     Json
  features   Json
  outcome    String?  @db.VarChar(50)
  reward     Float?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([agentType])
  @@index([niche])
  @@index([outcome])
  @@index([createdAt])
  @@map("agent_actions")
}

model AgentInsight {
  id           String   @id @default(uuid()) @db.Uuid
  sourceAgent  String   @map("source_agent") @db.VarChar(50)
  targetAgents String[] @default([]) @map("target_agents")
  niche        String?  @db.VarChar(100)
  language     String   @default("en") @db.VarChar(10)
  insightType  String   @map("insight_type") @db.VarChar(50)
  pattern      Json
  confidence   Float    @default(0.5)
  sampleSize   Int      @default(1) @map("sample_size")
  isActive     Boolean  @default(true) @map("is_active")
  appliedCount Int      @default(0) @map("applied_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([sourceAgent])
  @@index([niche])
  @@index([isActive])
  @@map("agent_insights")
}

// ─── Agency / White-label System ─────────────────────────────────────────────

model Agency {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  logoUrl      String? @map("logo_url")
  primaryColor String? @default("#7B5CF0") @map("primary_color")

  ownerId String @unique @map("owner_id") @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id])

  clients AgencyClient[]

  commissionPct Float @default(0.20) @map("commission_pct")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("agencies")
}

model AgencyClient {
  id       String   @id @default(cuid())
  agencyId String   @map("agency_id")
  agency   Agency   @relation(fields: [agencyId], references: [id])
  clientId String   @map("client_id") @db.Uuid
  client   Client   @relation(fields: [clientId], references: [id])
  addedAt  DateTime @default(now()) @map("added_at")

  @@unique([agencyId, clientId])
  @@map("agency_clients")
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id])
  permissions String[]  @default(["read"])
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}
