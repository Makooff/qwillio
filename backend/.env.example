# ── General ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-vercel-app.vercel.app
API_BASE_URL=https://qwillio.onrender.com
TZ=Europe/Brussels

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth / JWT ────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_LINK_BASIC=https://buy.stripe.com/xxx
STRIPE_LINK_PRO=https://buy.stripe.com/xxx
STRIPE_LINK_ENTERPRISE=https://buy.stripe.com/xxx
STRIPE_PRICE_BASIC_SETUP=price_xxx
STRIPE_PRICE_BASIC_MONTHLY=price_xxx
STRIPE_PRICE_PRO_SETUP=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_SETUP=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=Qwillio <noreply@qwillio.com>
RESEND_REPLY_TO=contact@qwillio.com

# ── VAPI (Voice AI) ───────────────────────────────────────
VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_ASSISTANT_ID=your_assistant_id
VAPI_PHONE_NUMBER=+1xxxxxxxxxx
VAPI_PHONE_NUMBER_ID=your_phone_number_id
VAPI_BASE_URL=https://api.vapi.ai
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret

# ── Twilio (SMS) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
SMS_ENABLED=false

# ── Discord Webhooks ──────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_CALLS=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_LEADS=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_SYSTEM=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/xxx
# Dedicated errors channel (id 1458455361337167983). Create a webhook on that
# channel and paste the full URL here. Falls back to DISCORD_WEBHOOK_ALERTS.
DISCORD_WEBHOOK_ERRORS=https://discord.com/api/webhooks/xxx

# ── Apify (Google Maps scraping) ──────────────────────────
APIFY_API_KEY=your_apify_api_key
APIFY_ACTOR_ID=nwua9Gu5YkAT85Sp6

# ── AI APIs ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key
OPENAI_API_KEY=sk-your_key

# ── Prospecting / Automation ──────────────────────────────
CALLS_PER_DAY=50
AUTOMATION_START_HOUR=9
AUTOMATION_END_HOUR=19
AUTOMATION_DAYS=1,2,3,4,5
CALL_INTERVAL_MINUTES=20
PROSPECTION_DAILY_QUOTA=30
PROSPECTION_RADIUS_METERS=5000
PROSPECTION_CITIES=Bruxelles,Anvers,Gand
MIN_PRIORITY_SCORE=10

# ── Demo Links ────────────────────────────────────────────
DEMO_LINK_EN=https://qwillio.com/demo
DEMO_LINK_FR=https://qwillio.com/demo-fr

# ── DocuSign ─────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=your_integration_key
DOCUSIGN_USER_ID=your_user_guid
DOCUSIGN_ACCOUNT_ID=your_account_id
DOCUSIGN_PRIVATE_KEY=base64_encoded_rsa_private_key
DOCUSIGN_AUTH_SERVER=account.docusign.com
DOCUSIGN_WEBHOOK_SECRET=your_webhook_secret

# ── Admin ────────────────────────────────────────────────
ADMIN_EMAIL=makho.off@gmail.com
ADMIN_SECRET=your_admin_secret

# ── Monitoring ───────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
