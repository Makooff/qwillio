# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://n8n_user:YOUR_PASSWORD@localhost:5432/n8n_db
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=n8n_db
POSTGRES_PORT=5432

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================================
# VAPI (Appels IA)
# ============================================================
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_PRIVATE_KEY=your-vapi-private-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER=+1234567890
VAPI_BASE_URL=https://api.vapi.ai
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
VAPI_MODEL=gpt-4-turbo
VAPI_VOICE_PROVIDER=11labs
VAPI_VOICE_ID=21m00Tcm4TlvDq8ikWAM
VAPI_STABILITY=0.75
VAPI_SIMILARITY_BOOST=0.85
VAPI_TEMPERATURE=0.7
VAPI_MAX_TOKENS=500

# ============================================================
# STRIPE (Paiements)
# ============================================================
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

STRIPE_PRICE_BASIC_SETUP=price_basic_setup
STRIPE_PRICE_BASIC_MONTHLY=price_basic_monthly
STRIPE_PRICE_PRO_SETUP=price_pro_setup
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_ENTERPRISE_SETUP=price_enterprise_setup
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly

STRIPE_LINK_BASIC=https://buy.stripe.com/XXXXX
STRIPE_LINK_PRO=https://buy.stripe.com/XXXXX
STRIPE_LINK_ENTERPRISE=https://buy.stripe.com/XXXXX

# ============================================================
# RESEND (Emails)
# ============================================================
RESEND_API_KEY=re_YOUR_API_KEY
RESEND_FROM_EMAIL=Marie - Bot Pulse <marie@botpulse.com>
RESEND_FROM_NAME=Marie - Bot Pulse
RESEND_REPLY_TO=contact@botpulse.com

# ============================================================
# GOOGLE PLACES API
# ============================================================
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_API_KEY

# ============================================================
# DISCORD NOTIFICATIONS
# ============================================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK

# ============================================================
# AUTOMATION SETTINGS
# ============================================================
CALLS_PER_DAY=50
AUTOMATION_START_HOUR=9
AUTOMATION_END_HOUR=19
AUTOMATION_DAYS=1,2,3,4,5
CALL_INTERVAL_MINUTES=20
PROSPECTION_DAILY_QUOTA=30
PROSPECTION_RADIUS_METERS=5000
PROSPECTION_CITIES=Bruxelles,Anvers,Gand,Liège,Namur,Charleroi

# ============================================================
# TIMEZONE
# ============================================================
TZ=Europe/Brussels
